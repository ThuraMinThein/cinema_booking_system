# ─────────────────────────────────────────────────────────────────────────────
# secrets.yaml.example
#
# DO NOT commit a populated secrets.yaml to git!
# 1. Copy this file to secrets.yaml
# 2. base64-encode each value:   echo -n 'my-value' | base64
# 3. Fill in the encoded values below
# 4. Apply:   kubectl apply -f k8s/secrets/secrets.yaml -n cinema-booking
# ─────────────────────────────────────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: cinema-secrets
  namespace: cinema-booking
type: Opaque
data:
  # echo -n 'your-jwt-secret' | base64
  jwt-secret-key: Y2hhbmdlLW1lLWluLXByb2R1Y3Rpb24=

  # Users DB
  users-db-password: eW91ci1wYXNzd29yZA==

  # Bookings DB
  bookings-db-password: eW91ci1wYXNzd29yZA==

  # Seats DB
  seats-db-password: eW91ci1wYXNzd29yZA==

  # Redis
  redis-password: eW91ci1yZWRpcy1wYXNzd29yZA==
