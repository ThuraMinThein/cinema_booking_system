# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  Root environment variables for docker-compose local dev
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file with real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared ────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production

# ── Docker Hub (used by docker-compose.prod.yml) ─────────────────────────────
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKER_IMAGE_TAG=latest

# ── Redis (shared across services) ───────────────────────────────────────────
REDIS_URL=your-redis-host:port
REDIS_USERNAME=default
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# ── Users Service DB ──────────────────────────────────────────────────────────
USERS_DB_HOST=your-neon-host.neon.tech
USERS_DB_PORT=5432
USERS_DB_USER=neondb_owner
USERS_DB_PASSWORD=your-password
USERS_DB_NAME=user_service

# ── Bookings Service DB ───────────────────────────────────────────────────────
BOOKINGS_DB_HOST=your-neon-host.neon.tech
BOOKINGS_DB_PORT=5432
BOOKINGS_DB_USER=neondb_owner
BOOKINGS_DB_PASSWORD=your-password
BOOKINGS_DB_NAME=booking_service

# ── Seats Service DB ──────────────────────────────────────────────────────────
SEATS_DB_HOST=your-neon-host.neon.tech
SEATS_DB_PORT=5432
SEATS_DB_USER=neondb_owner
SEATS_DB_PASSWORD=your-password
SEATS_DB_NAME=seat_service
